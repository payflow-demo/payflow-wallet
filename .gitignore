# ═══════════════════════════════════════════════════════════════
# Secrets & credentials (never commit these)
# ═══════════════════════════════════════════════════════════════

# Environment — real values live only on your machine
.env
.env.*
!.env.example
!.env.*.example

# Package manager tokens (npm, Yarn Berry)
.npmrc
!.npmrc.example
.yarnrc.yml
!.yarnrc.example
.pnpm-debug.log*

# SSH / TLS material (if copied into the repo by mistake)
*.pem
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_ed25519
id_ecdsa
*_rsa
*_ed25519
*.key
!**/.gitkeep
*.crt
*.cert
*.csr

# Kubeconfig exports (often pasted during debugging)
kubeconfig
*.kubeconfig
kube-config.yaml
**/kubeconfig-*

# Cloud & identity CLI dumps
azure-credentials.json
application_default_credentials.json
**/gcp-*-credentials.json
**/service-account*.json
!**/*credentials*.example.json
.aws/credentials
.aws/config
.azure/

# Cloudflare Tunnel (tokens live in ~/.cloudflared — never copy into repo)
.cloudflared/
cloudflared*.pem
**/cloudflare-tunnel-token.txt
**/cloudflare-credentials.json
k8s/secrets/cloudflare-tunnel-secret.yaml

# Generic high-risk filenames (narrow exceptions if you add *.example)
*.secret
*.secrets
secrets/
!secrets/.gitkeep

# Terraform sensitive inputs & state
**/.terraform/
*.tfstate
*.tfstate.*
*.tfplan
tfplan
tfplan.bin
.terraform.lock.hcl
override.tf
override.tf.json
*_override.tf
*_override.tf.json
**/backend.tf.backup
backend-config.hcl
*.tfvars
!*.tfvars.example
terraform.tfvars
terraform/aws/spoke-vpc-eks/terraform.tfvars
terraform/aws/managed-services/terraform.tfvars
terraform/aws/finops/terraform.tfvars
terraform/azure/finops/terraform.tfvars
variables/finops.tfvars
terraform/aws/managed-services/.secret-*.json

# Kubernetes — real cluster secrets (local overlay uses committed dev secrets by design;
# ignore copies or alternate paths that hold production values)
k8s/base/secrets/db-secrets.yaml
k8s/secrets/db-secrets.yaml

# TLS under ingress (generated locally)
k8s/ingress/certs/*.key
k8s/ingress/certs/*.crt
!k8s/ingress/certs/.gitkeep

# Plans & crash output that may embed resource IDs
**/apply.plan
**/*.plan
crash.log
crash.*.log

# Local overrides & scratch
*.local.yaml
*.local.yml
secrets.local.*
local-secrets.*
**/override-values.yaml
.envrc

# ═══════════════════════════════════════════════════════════════
# Dependencies & build
# ═══════════════════════════════════════════════════════════════

node_modules/
dist/
build/
coverage/
.nyc_output/

# ═══════════════════════════════════════════════════════════════
# Logs & OS
# ═══════════════════════════════════════════════════════════════

logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# macOS folder metadata (never commit — use `git rm --cached '**/.DS_Store'` if slipped in)
.DS_Store
**/.DS_Store
Thumbs.db

# ═══════════════════════════════════════════════════════════════
# Editor / tooling (local-only)
# ═══════════════════════════════════════════════════════════════

.vscode/
.idea/
*.swp
*.swo
*~
# Cursor IDE config (local / team choice — not part of app source)
.cursor/
.codacy/

# ═══════════════════════════════════════════════════════════════
# Project-specific (non-secret housekeeping)
# ═══════════════════════════════════════════════════════════════

# Local MicroK8s deploy script counter (machine-specific)
.mk8-deploy-number

DEBUG_USER_LIST.md
docs/CONTENT-NOTES.md
docs/EKS-MIGRATION-MENTEE-INSTRUCTIONS.md
docs/AUDIT-FOLLOW-UP-*.md
book/
cloud/
tf-infra-docs/

# Docker Hub push logs (may contain registry hints)
docker-push*.log
*_push.log

# Archives produced during image transfer / backup (can be huge)
*.image.tar
payflow-*.tar
